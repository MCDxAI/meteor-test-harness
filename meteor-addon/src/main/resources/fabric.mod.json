{
  "schemaVersion": 1,
  "id": "mc-test-harness-meteor",
  "version": "${version}",
  "name": "MC Test Harness (Meteor)",
  "description": "MCP HTTP server addon for automating Meteor addon testing via DOM-first control.",
  "authors": [
    "GhostTypes"
  ],
  "contact": {
    "homepage": "https://github.com/MCDxAI/mc-test-harness",
    "sources": "https://github.com/MCDxAI/mc-test-harness"
  },
  "icon": "assets/mc-test-harness-meteor/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "io.mcdxai.harness.McTestHarnessAddon"
    ]
  },
  "mixins": [
    "mc-test-harness-meteor.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "120,210,120"
  },
  "depends": {
    "java": ">=25",
    "minecraft": ">=${mc_version}",
    "meteor-client": ">=0.5.0"
  }
}
