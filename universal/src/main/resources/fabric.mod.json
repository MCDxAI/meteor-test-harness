{
  "schemaVersion": 1,
  "id": "mc-test-harness-universal",
  "version": "${version}",
  "name": "MC Test Harness (Universal)",
  "description": "Universal MCP HTTP server for automated GUI testing of Fabric mods. Vanilla + owo-lib + hybrid screen support.",
  "authors": [
    "GhostTypes"
  ],
  "contact": {
    "homepage": "https://github.com/MCDxAI/mc-test-harness",
    "sources": "https://github.com/MCDxAI/mc-test-harness"
  },
  "environment": "client",
  "entrypoints": {
    "client": [
      "io.mcdxai.harness.universal.UniversalHarnessMod"
    ]
  },
  "mixins": [
    "mc-test-harness-universal.mixins.json"
  ],
  "depends": {
    "java": ">=25",
    "minecraft": ">=${mc_version}",
    "fabricloader": ">=0.16.0",
    "fabric-api": "*"
  },
  "recommends": {
    "owo": "*"
  }
}
